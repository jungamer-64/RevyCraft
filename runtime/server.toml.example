# Minecraft-like runtime config for the Rust server

[static.bootstrap]
online_mode = false
level_name = "world"
level_type = "flat"
game_mode = 0
difficulty = 1
view_distance = 2
world_dir = "world"
storage_profile = "je-anvil-1_7_10"

[static.plugins]
plugins_dir = "plugins"
plugin_abi_min = "3.0"
plugin_abi_max = "3.0"

[static.admin.grpc]
enabled = false
bind_addr = "127.0.0.1:50051"
allow_non_loopback = false

[live.network]
server_ip = ""
server_port = 25565
motd = "Multi-version Rust server"
max_players = 20

[live.topology]
be_enabled = true
default_adapter = "je-5"
enabled_adapters = ["je-5", "je-47", "je-340"]
default_bedrock_adapter = "be-924"
enabled_bedrock_adapters = ["be-924"]
reload_watch = false
drain_grace_secs = 30

[live.plugins]
allowlist = [
  "je-5",
  "je-47",
  "je-340",
  "be-924",
  "gameplay-canonical",
  "gameplay-readonly",
  "storage-je-anvil-1_7_10",
  "auth-offline",
  "auth-bedrock-offline",
  "admin-ui-console",
]
reload_watch = false

[live.plugins.failure_policy]
protocol = "quarantine"
gameplay = "quarantine"
storage = "fail-fast"
auth = "skip"
admin_ui = "skip"

[live.profiles]
auth = "offline-v1"
bedrock_auth = "bedrock-offline-v1"
default_gameplay = "canonical"

[live.admin]
ui_profile = "console-v1"
local_console_permissions = [
  "status",
  "sessions",
  "reload-config",
  "reload-plugins",
  "reload-generation",
  "shutdown",
]

# To enable remote unary gRPC admin control:
# 1. create a token file outside version control, for example `runtime/admin/ops.token`
# 2. put a bearer token on its first line
# 3. enable the transport and define at least one principal:
#
# [static.admin.grpc]
# enabled = true
# bind_addr = "0.0.0.0:50051"
# allow_non_loopback = true
#
# [static.admin.grpc.principals.ops]
# token_file = "admin/ops.token"
# permissions = ["status", "sessions", "reload-config", "reload-plugins", "reload-generation", "shutdown"]
#
# The built-in gRPC server is plaintext h2 only. Non-loopback exposure is rejected
# unless `allow_non_loopback = true` is set explicitly. Put TLS and public exposure
# policy in a reverse proxy or ingress in front of this process.

# For JE online mode, set:
# [static.bootstrap]
# online_mode = true
# [live.profiles]
# auth = "mojang-online-v1"
#
# This sample allowlist is a minimal baseline.
# Add `auth-mojang-online` before enabling JE online mode.
# Add `auth-bedrock-xbl` before using `bedrock_auth = "bedrock-xbl-v1"`.

[live.profiles.gameplay_map]
"je-5" = "readonly"
"je-47" = "canonical"
"je-340" = "canonical"
"be-924" = "canonical"
