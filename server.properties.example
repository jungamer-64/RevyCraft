# Minecraft-like server properties for the Rust runtime
server-ip=
server-port=25565
be-enabled=false
motd=Multi-version Rust server
max-players=20
online-mode=false
level-name=world
level-type=FLAT
gamemode=0
difficulty=1
view-distance=2
default-adapter=je-1_7_10
enabled-adapters=je-1_7_10,je-1_8_x,je-1_12_2
default-bedrock-adapter=be-26_3
enabled-bedrock-adapters=be-26_3
storage-profile=je-anvil-1_7_10
auth-profile=offline-v1
bedrock-auth-profile=bedrock-offline-v1
# For JE online mode, set:
# online-mode=true
# auth-profile=mojang-online-v1
default-gameplay-profile=canonical
gameplay-profile-map=je-1_7_10:readonly,je-1_8_x:canonical,je-1_12_2:canonical,be-26_3:canonical
plugins-dir=dist/plugins
plugin-allowlist=je-1_7_10,je-1_8_x,je-1_12_2,be-26_3,be-placeholder,gameplay-canonical,gameplay-readonly,storage-je-anvil-1_7_10,auth-offline,auth-mojang-online,auth-bedrock-offline,auth-bedrock-xbl
plugin-failure-policy=quarantine
plugin-reload-watch=false
plugin-abi-min=1.0
plugin-abi-max=1.0
